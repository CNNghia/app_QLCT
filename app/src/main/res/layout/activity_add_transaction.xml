<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Header Actions -->
    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/textColorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LƯU"
        android:textColor="@color/colorPrimary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Nút gạt Thu / Chi -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleTransactionType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btnTypeExpense"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/btnClose"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTypeIncome"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THU NHẬP"
            android:textColor="#4CAF50" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTypeExpense"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHI TIÊU"
            android:textColor="#F44336" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Khu vực nhập Tiền (Nửa trên) -->
    <LinearLayout
        android:id="@+id/layoutInputTop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/toggleTransactionType"
        app:layout_constraintBottom_toTopOf="@+id/layoutBottomForm">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SỐ TIỀN"
            android:textColor="@color/textColorSecondary"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <EditText
            android:id="@+id/etInputAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:hint="0"
            android:inputType="numberDecimal"
            android:background="@null"
            android:textColor="@color/colorPrimary"
            android:textColorHint="#BDBDBD"
            android:textSize="64sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLength="12"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VNĐ"
            android:textColor="@color/textColorSecondary"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Khu vực nhập Chi tiết Giao dịch (Nửa dưới kiểu Card xịn) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutBottomForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorCard"
        app:cardElevation="24dp"
        app:cardCornerRadius="24dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Phân loại Danh mục -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" DANH MỤC "
                android:background="#E8E8E8"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="#546E7A"
                android:textStyle="bold"
                android:textSize="10sp" />

            <LinearLayout
                android:id="@+id/btnSelectCategory"
                android:background="?attr/selectableItemBackground"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/ivCategoryIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_icon"
                    android:backgroundTint="@color/colorPrimaryVariant"
                    android:src="@drawable/ic_transaction"
                    app:tint="@color/white"
                    android:padding="8dp"/>

                <TextView
                    android:id="@+id/tvCategoryName"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Chọn danh mục"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Mũi tên thả xuống (Dropdown Icon) -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#9E9E9E" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="24dp" />

            <!-- Ghi chú nhập liệu -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" GHI CHÚ "
                android:background="#E8E8E8"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="#546E7A"
                android:textStyle="bold"
                android:textSize="10sp" />

            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Nhập diễn giải cho chi tiêu này..."
                android:paddingVertical="8dp"
                android:textSize="16sp"
                android:textColor="@color/textColorPrimary" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="24dp" />

            <!-- Chọn Ngày & Chọn Ví (Chia đôi màn hình) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btnSelectDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" THỜI GIAN "
                        android:background="#E8E8E8"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:textColor="#546E7A"
                        android:textStyle="bold"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">
                        <TextView
                            android:id="@+id/tvSelectedDateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hôm nay"
                            android:textColor="@color/textColorPrimary"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="4dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#9E9E9E" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Đường kẻ mờ phân chia dọc -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#E0E0E0"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginVertical="8dp" />

                <LinearLayout
                    android:id="@+id/btnSelectWallet"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" NGUỒN TIỀN "
                        android:background="#E8E8E8"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:textColor="#546E7A"
                        android:textStyle="bold"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">
                        <TextView
                            android:id="@+id/tvWalletName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ví Tiền Mặt"
                            android:textColor="@color/textColorPrimary"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="4dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="#9E9E9E" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>